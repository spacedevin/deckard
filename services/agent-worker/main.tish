// Co-DJ agent worker (Tish): connect to gateway, join as agent, handle direct + human play with LLM.
// Run: tish run --features ws,process,http services/agent-worker/main.tish
import { WebSocket } from "tish:ws"
import { process } from "tish:process"
import { fetch } from "http"

let actorId = "agent-1"
let hub = "ws://127.0.0.1:35987"
let session = "default"
let argv = typeof process !== "undefined" && process.argv ? process.argv : []
let ai = 0
while (ai < argv.length) {
  if (ai + 1 < argv.length && argv[ai] === "--actor-id") {
    actorId = argv[ai + 1]
    ai = ai + 2
    continue
  }
  if (ai + 1 < argv.length && argv[ai] === "--lane") {
    actorId = "agent-" + argv[ai + 1]
    ai = ai + 2
    continue
  }
  if (ai + 1 < argv.length && argv[ai] === "--hub") {
    hub = argv[ai + 1]
    ai = ai + 2
    continue
  }
  if (ai + 1 < argv.length && argv[ai] === "--session") {
    session = argv[ai + 1]
    ai = ai + 2
    continue
  }
  ai = ai + 1
}

let DO_BASE = "https://inference.do-ai.run/v1"
if (typeof process !== "undefined" && process.env && "DO_INFERENCE_BASE" in process.env) {
  DO_BASE = process.env["DO_INFERENCE_BASE"]
}
if (DO_BASE.endsWith("/")) { DO_BASE = DO_BASE.substring(0, DO_BASE.length - 1) }
let DO_MODEL = "llama3-8b-instruct"
if (typeof process !== "undefined" && process.env && "DO_MODEL" in process.env) {
  DO_MODEL = process.env["DO_MODEL"]
}
let GRADIENT_MODEL_ACCESS_KEY = ""
if (typeof process !== "undefined" && process.env) {
  if ("GRADIENT_MODEL_ACCESS_KEY" in process.env) { GRADIENT_MODEL_ACCESS_KEY = process.env["GRADIENT_MODEL_ACCESS_KEY"] }
  else if ("MODEL_ACCESS_KEY" in process.env) { GRADIENT_MODEL_ACCESS_KEY = process.env["MODEL_ACCESS_KEY"] }
}

let SYSTEM_PROMPT = "You are a Co-DJ agent. Output ONLY valid TPL lines. No markdown, no explanation.\nUse track ids prefixed with \"" + actorId + "_\" (e.g. " + actorId + "_hat, " + actorId + "_bass).\nGenerators: noise_burst (noise attack decay tone pitch_follow + steps), fm (fm ratio mod_index carrier mod + adsr + steps), basic_osc (osc waveform + adsr + steps).\nPatterns: steps with 16 x/. tokens, or steps euclid <hits> 16.\nComplement the human's project: add hi-hats, percussion, bass, or melodic parts that fit the tempo and fill gaps."

let SKILL_IDS = ["add_track", "adjust_instrument", "pattern_steps", "pattern_piano", "channel_mix"]

fn buildDemoPatch(text) {
  let lower = text.toLowerCase()
  if (lower.indexOf("euclid") >= 0 || lower.indexOf("hat") >= 0 || lower.indexOf("hihat") >= 0) {
    return "tpl 1\ntrack AgentHat id " + actorId + "_hat gen noise_burst\n  noise attack 0.001 decay 0.04 tone 0.9 pitch_follow 0.1\n  steps euclid 5 16"
  }
  if (lower.indexOf("bass") >= 0 || lower.indexOf("fm") >= 0) {
    return "tpl 1\ntrack AgentBass id " + actorId + "_bass gen fm\n  fm ratio 2 mod_index 5 carrier sine mod square\n  adsr a 0.01 d 0.1 s 0.3 r 0.15\n  steps x . x . x . x . x . x . x . x ."
  }
  return null
}

fn lineStartsWithSpace(l) {
  let c = l.charAt(0)
  return c === " " || c === "\t"
}
fn lineStartsWithTplKeyword(t) {
  let prefixes = ["noise ", "fm ", "osc ", "adsr ", "steps ", "note ", "mix "]
  let i = 0
  while (i < prefixes.length) {
    if (t.indexOf(prefixes[i]) === 0) return true
    i = i + 1
  }
  return false
}

/** Extract TPL lines from LLM output. Strips markdown, keeps valid TPL. */
fn extractTplFromResponse(raw) {
  let s = String(raw || "").trim()
  let codeBlock = RegExp("```(?:[a-zA-Z0-9_]*)\\n?([\\s\\S]*?)```")
  let m = s.match(codeBlock)
  if (m != null && m.length > 1) s = m[1].trim()
  let all = s.split("\n")
  let out = []
  let i = 0
  while (i < all.length) {
    let l = all[i]
    let t = l.trim()
    if (!t || t.charAt(0) === "#" || t.indexOf("Here") === 0 || t.toLowerCase().indexOf("sure") === 0) {
      i = i + 1
      continue
    }
    let norm = l.split("\t").join("  ")
    if (t.indexOf("tpl ") === 0 || t.indexOf("track ") === 0 || t.indexOf("bpm ") === 0 || t.indexOf("auto ") === 0) {
      out.push(norm)
    } else if (lineStartsWithSpace(l) && t) {
      out.push(norm)
    } else if (out.length > 0 && lineStartsWithTplKeyword(t)) {
      out.push("  " + t)
    }
    i = i + 1
  }
  if (out.length === 0) return null
  let first = out[0].trim()
  if (first.indexOf("tpl ") !== 0 && first.indexOf("track ") !== 0) return null
  if (first.indexOf("tpl ") !== 0) {
    let newOut = ["tpl 1"]
    let j = 0
    while (j < out.length) {
      newOut.push(out[j])
      j = j + 1
    }
    out = newOut
  }
  return out
}

fn callLLM(userPrompt) {
  if (!GRADIENT_MODEL_ACCESS_KEY || GRADIENT_MODEL_ACCESS_KEY === "") return null
  try {
    let url = DO_BASE + "/chat/completions"
    let bodyObj = {
      model: DO_MODEL,
      messages: [
        { role: "system", content: SYSTEM_PROMPT },
        { role: "user", content: userPrompt }
      ],
      max_tokens: 1024,
      temperature: 0.7
    }
    let bodyStr = JSON.stringify(bodyObj)
    let headersObj = {}
    headersObj["Content-Type"] = "application/json"
    headersObj["Authorization"] = "Bearer " + GRADIENT_MODEL_ACCESS_KEY
    let opts = {
      method: "POST",
      headers: headersObj,
      body: bodyStr
    }
    let resp = await fetch(url, opts)
    if (!resp || !resp.ok) {
      let errText = ""
      try {
        let errData = await resp.text()
        errText = errData
      } catch (e) {
        errText = String(resp.status || "unknown")
      }
      console.error("[agent] LLM error:", errText)
      return null
    }
    let data = await resp.json()
    if (!data || typeof data !== "object") return null
    let choices = data.choices
    if (!choices || !Array.isArray(choices) || choices.length === 0) return null
    let msg = choices[0].message
    if (!msg || typeof msg !== "object") return null
    let content = msg.content
    if (!content) return null
    return extractTplFromResponse(content)
  } catch (e) {
    console.error("[agent] LLM fetch failed:", String(e))
    return null
  }
}

let activeWs = null

fn handleDirect(ws, msg) {
  let text = msg.text || "add hi-hat"
  let ps = (msg.perfStep != null && typeof msg.perfStep === "number") ? msg.perfStep : 0
  let lines = null
  if (GRADIENT_MODEL_ACCESS_KEY && GRADIENT_MODEL_ACCESS_KEY !== "") {
    lines = callLLM("Add a track for: \"" + text + "\". Output ONLY TPL.")
  }
  if (!lines || lines.length === 0) {
    let demo = buildDemoPatch(text)
    if (demo) lines = demo.split("\n")
  }
  if (!lines || lines.length === 0 || !ws || !ws.send) return
  ws.send(JSON.stringify({
    type: "tpl.block",
    actorId: actorId,
    authorId: actorId,
    lines: lines,
    effectivePerfStep: ps,
    asap: true
  }))
  console.log("[agent] got direct:", text, "-> sent tpl.block")
}

// Human play flow: buffer tpl.line from playing actor; after debounce emit stream_chunk then tpl.block
let playingActorId = null
let humanLineBuffer = []
let lastLineAt = 0
let respondedSincePlay = false
let DEBOUNCE_MS = 1300

fn streamChunkThenBlock(ws, lines, perfStep) {
  if (!ws || !ws.send) { return }
  let text = lines.join("\n")
  let i = 0
  while (i < text.length) {
    ws.send(JSON.stringify({ type: "tpl.stream_chunk", actorId: actorId, authorId: actorId, chunk: text.substring(i, i + 1) }))
    i = i + 1
    let _d = 0
    while (_d < 80000) { _d = _d + 1 }
  }
  if (ws && ws.send) {
    ws.send(JSON.stringify({
      type: "tpl.block",
      actorId: actorId,
      authorId: actorId,
      lines: lines,
      effectivePerfStep: perfStep,
      asap: true
    }))
  }
}

fn handleHumanStream(ws, perfStep) {
  let humanTpl = humanLineBuffer.join("\n").trim()
  let lines = null
  if (GRADIENT_MODEL_ACCESS_KEY && GRADIENT_MODEL_ACCESS_KEY !== "" && humanTpl.length > 10) {
    console.log("[agent] calling LLM with", String(humanTpl.length), "chars of human TPL")
    lines = callLLM("Human's current project TPL (complement it with a new track):\n\n" + humanTpl)
  }
  if (!lines || lines.length === 0) {
    let demo = buildDemoPatch("euclid hi-hat")
    if (demo) lines = demo.split("\n")
  }
  if (!lines || lines.length === 0) return
  console.log("[agent] play response: streaming", String(lines.length), "lines ->", playingActorId || "?")
  streamChunkThenBlock(ws, lines, perfStep)
  console.log("[agent] sent tpl.stream_chunk + tpl.block")
}

fn connectHub() {
  let url = hub
  if (url.endsWith("/")) { url = url.substring(0, url.length - 1) }
  let ws = null
  let tries = 0
  while (tries < 10) {
    console.log("[agent] connecting to " + url)
    ws = WebSocket(url)
    if (ws !== null) { break }
    tries = tries + 1
    console.warn("[agent] connect failed, retry in 2s", url, "attempt", tries)
    let _w = 0
    while (_w < 2000000) { _w = _w + 1 }
  }
  if (ws === null) {
    console.warn("[agent] connect failed after retries", url)
    return null
  }
  activeWs = ws
  console.log("[agent] WebSocket connected (handshake OK), sending join")
  ws.send(JSON.stringify({
    type: "join",
    sessionId: session,
    actorId: actorId,
    channelIds: ["default"],
    skillIds: SKILL_IDS
  }))
  console.log("[agent] joined " + session + " as " + actorId)
  return ws
}

fn run() {
  let ws = connectHub()
  if (ws === null) {
    process.exit(1)
  }
  console.log("[agent] enter receive loop")
  let joinedLogged = false
  while (true) {
    let msgObj = null
    try {
      msgObj = ws.receiveTimeout(500)
    } catch (e) {
      console.warn("[agent] loop error", e)
    }
    if (msgObj === null) { }
    else {
      let raw = (msgObj != null && msgObj.data != null) ? msgObj.data : null
      if (!raw) { }
      else {
        let msg = null
        try {
          msg = JSON.parse(raw)
        } catch (e) {
        }
        if (msg != null && msg.type === "direct") {
          let tgt = msg.targetActorId
          if (tgt === actorId || (tgt == null && msg.laneId === actorId)) {
            console.log("[agent] got direct: " + (msg.text || ""))
            handleDirect(ws, msg)
            console.log("[agent] sent tpl.block")
          }
        }
        else if (msg != null && msg.type === "control") {
          let op = msg.op || ""
          if (op === "human_play" || op === "playing_start") {
            playingActorId = msg.actorId || msg.authorId || null
            respondedSincePlay = false
            humanLineBuffer = []
            lastLineAt = Date.now()
            console.log("[agent] playing_start, buffering tpl.line from " + (playingActorId || "?"))
          }
          else if (op === "human_stop" || op === "playing_stop") {
            playingActorId = null
            humanLineBuffer = []
            respondedSincePlay = false
            console.log("[agent] playing_stop")
          }
        }
        else if (msg != null && msg.type === "tpl.line") {
          let from = msg.actorId || msg.authorId || msg.laneId || ""
          if (playingActorId != null && (from === playingActorId || (playingActorId === "" && from !== actorId))) {
            let line = msg.line
            if (typeof line === "string") {
              humanLineBuffer.push(line)
              lastLineAt = Date.now()
            }
          }
        }
        else if (msg != null && msg.type === "presence") {
          let al = msg.actors ? msg.actors : []
          console.log("[agent] presence: actors=" + JSON.stringify(al))
        }
        else if (msg != null && msg.type === "joined" && !joinedLogged) {
          joinedLogged = true
          console.log("[agent] received joined, ready")
        }
      }
    }
    if (playingActorId != null && !respondedSincePlay && humanLineBuffer.length > 0) {
      let elapsed = Date.now() - lastLineAt
      if (elapsed >= DEBOUNCE_MS) {
        respondedSincePlay = true
        let ps = 0
        handleHumanStream(ws, ps)
      }
    }
  }
}

run()
