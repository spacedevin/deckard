// Simulated "god agent": emits TPL applied as human lane (bpm, every track, autos, new tracks).

import { generatorIdToTpl } from '../tpl/Emit.tish'
import { coDjCurrentPerfStep, coDjStepsPerSequence } from './Schedule.tish'

fn rnd(n) {
  return Math.floor(Math.random() * n)
}

fn pickGrid16() {
  let pat = [
    "x . x . x . x . x . x . x . x .",
    "x x . . x x . . x x . . x x . .",
    "x . . x . x . x . . x . x . x ."
  ]
  return "  steps " + pat[rnd(pat.length)]
}

fn pickEuclid() {
  return "  steps euclid " + String(3 + rnd(10)) + " " + String(8 + rnd(8))
}

/** Debug: heavy churn — every channel, autos, bonus tracks. Always 2 blocks, both ASAP. */
export fn coDjBuildFullControlAgentDemo(project) {
  let lines = []
  let bpm = 88 + rnd(45)
  lines.push("bpm " + String(bpm))
  lines.push("tpl 1")
  if (rnd(2) === 0) {
    lines.push("auto master_gain")
    lines.push("  0 " + String(0.85 + rnd(25) * 0.01))
    lines.push("  4 " + String(0.95 + rnd(15) * 0.01))
    lines.push("  8 " + String(0.8 + rnd(30) * 0.01))
    lines.push("  16 " + String(0.9 + rnd(20) * 0.01))
  }
  let chs = project.channels
  let n = chs.length
  if (n > 16) {
    n = 16
  }
  let ci = 0
  while (ci < n && ci < chs.length) {
    let ch = chs[ci]
    let gid = ch.generatorId
    if (!gid) {
      gid = "basicOsc"
    }
    let genRoll = rnd(4)
    let tplGen = generatorIdToTpl(gid)
    if (genRoll === 0) {
      tplGen = "noise_burst"
    }
    if (genRoll === 1) {
      tplGen = "fm"
    }
    if (genRoll === 2) {
      tplGen = "basic_osc"
    }
    lines.push("track " + ch.name + " id " + ch.id + " gen " + tplGen)
    let g0 = 0.35 + rnd(60) * 0.01
    let p0 = (rnd(21) - 10) * 0.1
    lines.push("  mix gain " + String(g0) + " pan " + String(p0))
    if (tplGen === "noise_burst") {
      lines.push(
        "  noise attack 0.001 decay " +
          String(0.015 + rnd(12) * 0.006) +
          " tone " +
          String(0.2 + rnd(70) * 0.01) +
          " pitch_follow " +
          String(0.03 + rnd(25) * 0.01)
      )
    }
    if (tplGen === "fm") {
      lines.push(
        "  fm ratio " +
          String(1 + rnd(6)) +
          " mod_index " +
          String(3 + rnd(30)) +
          " carrier sine mod triangle"
      )
      lines.push("  adsr a 0.006 d " + String(0.05 + rnd(14) * 0.01) + " s 0.35 r 0.12")
    }
    if (tplGen === "basic_osc") {
      let waves = ["sine", "square", "saw"]
      lines.push("  osc waveform " + waves[rnd(3)])
      lines.push("  adsr a 0.003 d 0.08 s 0.45 r 0.1")
    }
    if (rnd(2) === 0) {
      lines.push(pickEuclid())
    } else {
      lines.push(pickGrid16())
    }
    if (rnd(10) < 6) {
      let pit = 36 + rnd(48)
      lines.push(
        "  note " + String(pit) + " " + String(rnd(12) * 0.25) + " 0.12 v " + String(75 + rnd(45))
      )
    }
    if (rnd(6) === 0 && tplGen === "noise_burst") {
      lines.push("auto " + ch.id + " gen tone")
      lines.push("  0 " + String(0.3 + rnd(40) * 0.01))
      lines.push("  8 " + String(0.7 + rnd(30) * 0.01))
      lines.push("  16 " + String(0.4 + rnd(50) * 0.01))
    }
    ci = ci + 1
  }
  let nid = "fullsim_" + String(1000 + rnd(9000))
  lines.push("track GodHat id " + nid + " gen noise_burst")
  lines.push("  noise attack 0.001 decay 0.03 tone 0.78 pitch_follow 0.2")
  lines.push("  mix gain 0.9 pan " + String((rnd(11) - 5) * 0.08))
  lines.push("  steps euclid " + String(5 + rnd(8)) + " 16")
  if (chs.length === 0) {
    let nid2 = "fullsim_bass_" + String(1000 + rnd(9000))
    lines.push("track GodBass id " + nid2 + " gen fm")
    lines.push("  fm ratio 2 mod_index 8 carrier sine mod square")
    lines.push("  adsr a 0.02 d 0.12 s 0.32 r 0.2")
    lines.push("  mix gain 0.78 pan -0.15")
    lines.push(pickGrid16())
  }
  let secondPatch = []
  secondPatch.push("tpl 1")
  secondPatch.push("bpm " + String(92 + rnd(38)))
  if (rnd(2) === 0) {
    secondPatch.push("auto master_gain")
    secondPatch.push("  0 0.88")
    secondPatch.push("  8 1.02")
    secondPatch.push("  16 0.92")
  }
  let cj = 0
  let max2 = chs.length
  if (max2 > 12) {
    max2 = 12
  }
  while (cj < max2 && cj < chs.length) {
    let ch2 = chs[cj]
    let g2 = ch2.generatorId
    if (!g2) {
      g2 = "basicOsc"
    }
    let tg2 = generatorIdToTpl(g2)
    let gen2 = rnd(3)
    if (gen2 === 0) {
      tg2 = "noise_burst"
    }
    if (gen2 === 1) {
      tg2 = "fm"
    }
    if (gen2 === 2) {
      tg2 = "basic_osc"
    }
    secondPatch.push("track " + ch2.name + " id " + ch2.id + " gen " + tg2)
    secondPatch.push("  mix gain " + String(0.4 + rnd(45) * 0.01) + " pan " + String((rnd(19) - 9) * 0.07))
    if (tg2 === "noise_burst") {
      secondPatch.push("  noise attack 0.002 decay " + String(0.025 + rnd(8) * 0.01) + " tone 0.5 pitch_follow 0.2")
    }
    if (tg2 === "fm") {
      secondPatch.push("  fm ratio " + String(2 + rnd(5)) + " mod_index " + String(6 + rnd(20)) + " carrier square mod sine")
    }
    secondPatch.push(rnd(2) === 0 ? pickEuclid() : pickGrid16())
    cj = cj + 1
  }
  return { primaryLines: lines, secondPatch: secondPatch }
}

export fn coDjFullSimSecondPerfStep() {
  return coDjCurrentPerfStep() + coDjStepsPerSequence()
}
